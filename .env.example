# Copy this file to .env.local and fill in your local Supabase project values.
# Do not commit .env.local or any real secrets.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Gemini key for AI generation and embeddings.
GEMINI_API_KEY=

# Optional server-only Upstash Redis credentials for burst rate limiting.
# When these are empty, Redis burst limiting is inactive and development falls
# back to the existing plan usage checks and safe logging.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App base URL for redirects and deployed links.
NEXT_PUBLIC_APP_URL=

